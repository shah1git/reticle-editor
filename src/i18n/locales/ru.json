    "lengthHint": "\u041a\u0430\u043a \u0434\u0430\u043b\u0435\u043a\u043e \u0442\u044f\u043d\u0435\u0442\u0441\u044f \u043a\u0440\u044b\u043b\u043e \u043e\u0442 \u0446\u0435\u043d\u0442\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u043e\u0447\u043a\u0438. 1 MRAD \u2248 10 \u0441\u043c \u043d\u0430 100 \u043c, \u2248 1 \u043c \u043d\u0430 1 \u043a\u043c.\n\n\u041f\u0440\u0438 \u0434\u043b\u0438\u043d\u0435 {{length}} \u0438 \u0438\u043d\u0442\u0435\u0440\u0432\u0430\u043b\u0435 {{spacing}} \u043d\u0430 \u043a\u0440\u044b\u043b\u0435 \u043f\u043e\u043c\u0435\u0441\u0442\u0438\u0442\u0441\u044f {{count}} \u043c\u0435\u0442\u043e\u043a. \u041f\u0440\u0438 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0438 0 \u043a\u0440\u044b\u043b\u043e \u043d\u0435 \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044f.",
    "lineThickness": "\u0422\u043e\u043b\u0449\u0438\u043d\u0430 \u043b\u0438\u043d\u0438\u0438",
    "lineThicknessHint": "\u0422\u043e\u043b\u0449\u0438\u043d\u0430 \u043b\u0438\u043d\u0438\u0438 \u043a\u0440\u044b\u043b\u0430 \u0432 MRAD. \u0422\u043e\u043d\u043a\u0430\u044f \u043b\u0438\u043d\u0438\u044f (0.05\u20130.1) \u043c\u0435\u043d\u044c\u0448\u0435 \u043f\u0435\u0440\u0435\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0446\u0435\u043b\u044c, \u0442\u043e\u043b\u0441\u0442\u0430\u044f (0.2+) \u043b\u0443\u0447\u0448\u0435 \u0432\u0438\u0434\u043d\u0430 \u043d\u0430 \u0448\u0443\u043c\u043d\u043e\u043c \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0438.\n\n\u0417\u043d\u0430\u0447\u0435\u043d\u0438\u0435 0 \u0434\u043e\u043f\u0443\u0441\u0442\u0438\u043c\u043e \u2014 \u043b\u0438\u043d\u0438\u044f \u043d\u0435 \u0440\u0438\u0441\u0443\u0435\u0442\u0441\u044f, \u043e\u0441\u0442\u0430\u044e\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0442\u043e\u0447\u043a\u0438-\u043c\u0435\u0442\u043a\u0438 (\u0435\u0441\u043b\u0438 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u044b). \u042d\u0442\u043e \u0443\u0434\u043e\u0431\u043d\u043e, \u043a\u043e\u0433\u0434\u0430 \u043d\u0443\u0436\u043d\u0430 \u0442\u043e\u043b\u044c\u043a\u043e \u0448\u043a\u0430\u043b\u0430 \u0431\u0435\u0437 \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u044f\u044e\u0449\u0435\u0439 \u043b\u0438\u043d\u0438\u0438.",
    "dotSize": "\u0420\u0410\u0417\u041c\u0415\u0420 \u0422\u041e\u0427\u041a\u0418",
    "dotSizeHint": "\u0414\u0438\u0430\u043c\u0435\u0442\u0440 \u043a\u0430\u0436\u0434\u043e\u0439 \u0442\u043e\u0447\u043a\u0438-\u043c\u0435\u0442\u043a\u0438 \u0432 \u043f\u0438\u043a\u0441\u0435\u043b\u044f\u0445. \u0417\u0430\u0434\u0430\u0451\u0442\u0441\u044f \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e \u2014 \u0431\u0435\u0437 \u043f\u0435\u0440\u0435\u0441\u0447\u0451\u0442\u0430 \u0438\u0437 MRAD. \u041a\u0430\u0436\u0434\u043e\u0435 \u043a\u0440\u044b\u043b\u043e \u043c\u043e\u0436\u0435\u0442 \u0438\u043c\u0435\u0442\u044c \u0441\u0432\u043e\u0439 \u0440\u0430\u0437\u043c\u0435\u0440.\n\n1 \u043f\u0438\u043a\u0441 \u2014 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u0430\u044f \u0442\u043e\u0447\u043a\u0430, \u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c \u043f\u043b\u043e\u0445\u043e \u0432\u0438\u0434\u043d\u0430. 2\u20133 \u043f\u0438\u043a\u0441 \u2014 \u0445\u043e\u0440\u043e\u0448\u043e \u0440\u0430\u0437\u043b\u0438\u0447\u0438\u043c\u0430\u044f \u043c\u0435\u0442\u043a\u0430. 4+ \u043f\u0438\u043a\u0441 \u2014 \u043a\u0440\u0443\u043f\u043d\u0430\u044f, \u0434\u043b\u044f \u043d\u0438\u0437\u043a\u0438\u0445 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043d\u0438\u0439.\n\n\u0422\u0435\u043a\u0443\u0449\u0438\u0439 \u0440\u0430\u0437\u043c\u0435\u0440 {{size}} \u043f\u0438\u043a\u0441 = {{mrad}} MRAD \u043d\u0430 \u044d\u0442\u043e\u0439 \u043e\u0441\u0438.",
    "interval": "\u0418\u043d\u0442\u0435\u0440\u0432\u0430\u043b",
    "intervalHint": "\u0420\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043c\u0435\u0436\u0434\u0443 \u0441\u043e\u0441\u0435\u0434\u043d\u0438\u043c\u0438 \u0442\u043e\u0447\u043a\u0430\u043c\u0438-\u043c\u0435\u0442\u043a\u0430\u043c\u0438 \u043d\u0430 \u043a\u0440\u044b\u043b\u0435 \u0432 MRAD. \u041e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u043a\u0430\u043a \u0447\u0430\u0441\u0442\u043e \u0440\u0430\u0441\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u044b \u0434\u0435\u043b\u0435\u043d\u0438\u044f \u0448\u043a\u0430\u043b\u044b.\n\n\u041f\u0440\u0438 \u0438\u043d\u0442\u0435\u0440\u0432\u0430\u043b\u0435 1.0 \u0438 \u0434\u043b\u0438\u043d\u0435 {{length}} \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0441\u044f {{count}} \u0442\u043e\u0447\u0435\u043a. \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043c\u0435\u0442\u043e\u043a = \u0434\u043b\u0438\u043d\u0430 \u00f7 \u0438\u043d\u0442\u0435\u0440\u0432\u0430\u043b (\u0434\u0440\u043e\u0431\u043d\u044b\u0435 \u043e\u0442\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u044e\u0442\u0441\u044f).\n\n\u0418\u043c\u0435\u043d\u043d\u043e \u044d\u0442\u043e\u0442 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440 \u043f\u043e\u0440\u043e\u0436\u0434\u0430\u0435\u0442 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0443 \u0440\u0430\u0441\u0442\u0435\u0440\u0438\u0437\u0430\u0446\u0438\u0438: \u0438\u043d\u0442\u0435\u0440\u0432\u0430\u043b \u00d7 \u043f\u0438\u043a\u0441\u0435\u043b\u0435\u0439 \u043d\u0430 MRAD \u043f\u043e\u0447\u0442\u0438 \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0440\u0430\u0432\u0435\u043d \u0446\u0435\u043b\u043e\u043c\u0443 \u0447\u0438\u0441\u043b\u0443 \u043f\u0438\u043a\u0441\u0435\u043b\u0435\u0439."
