FILE="package.json"
CURRENT=$(node -p "require('./$FILE').version")
IFS='.' read -r MAJOR MINOR PATCH <<EOF
$CURRENT
EOF
PATCH=$((PATCH + 1))
NEW="$MAJOR.$MINOR.$PATCH"

node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('$FILE','utf8'));
pkg.version = '$NEW';
fs.writeFileSync('$FILE', JSON.stringify(pkg, null, 2) + '\n');
"

git add "$FILE"
